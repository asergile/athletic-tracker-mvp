# Supabase Configuration
# Copy this file to .env.local and fill in your actual Supabase values

# Get these values from your Supabase project dashboard
# Project Settings > API > Project URL and Project API keys

REACT_APP_SUPABASE_URL=your-project-url-here
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Example format:
# REACT_APP_SUPABASE_URL=https://xyzcompany.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Note: These are safe to include in your React app as they are designed to be public
# The anon key only allows operations permitted by your Row Level Security policies